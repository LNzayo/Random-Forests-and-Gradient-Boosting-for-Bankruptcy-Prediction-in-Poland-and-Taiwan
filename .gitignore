```gitignore
# Byte-compiled / optimized files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# Python packaging
build/
dist/
*.egg-info/

# IDE settings
.vscode/
.idea/

# Operating system files
.DS_Store
Thumbs.db

# Environment variables
.env

# Model files
models/*.pkl
models/*.joblib

# Logs
*.log

# Pytest
.pytest_cache/

# Coverage reports
.coverage
htmlcov/

# MyPy
.mypy_cache/

# Ruff
.ruff_cache/

# Data files (optional - uncomment if datasets are large)
# data/
# *.csv
# *.xlsx
```
